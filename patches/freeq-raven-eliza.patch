+#[derive(Debug, Clone, Copy, PartialEq, Eq)]
+enum AnswerProvider {
+    Anthropic,
+    Groq,
+    Inception,
+}
+
+fn configured_answer_provider(cfg: &SharedConfig) -> AnswerProvider {
