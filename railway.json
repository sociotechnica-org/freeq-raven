{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "cargo build --release -p freeq-raven"
  },
  "deploy": {
    "startCommand": "./bin/freeq-raven-railway",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
