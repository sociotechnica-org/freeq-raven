#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PID_FILE="$ROOT/.runtime/freeq-raven.pid"
TMUX_SESSION="${RAVEN_TMUX_SESSION:-freeq-raven}"

if command -v tmux >/dev/null 2>&1 && tmux has-session -t "$TMUX_SESSION" 2>/dev/null; then
  tmux kill-session -t "$TMUX_SESSION"
  rm -f "$PID_FILE"
  echo "Stopped Raven tmux session: $TMUX_SESSION"
  exit 0
fi

if [[ ! -f "$PID_FILE" ]]; then
  echo "Raven is not running."
  exit 0
fi

pid="$(cat "$PID_FILE")"
if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
  kill "$pid"
  for _ in {1..20}; do
    if ! kill -0 "$pid" 2>/dev/null; then
      break
    fi
    sleep 0.25
  done
  if kill -0 "$pid" 2>/dev/null; then
    kill -9 "$pid" 2>/dev/null || true
  fi
fi
rm -f "$PID_FILE"
echo "Stopped Raven."
