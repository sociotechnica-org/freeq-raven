#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ENV_FILE="${RAVEN_ENV_FILE:-$ROOT/.env}"

if [[ ! -f "$ENV_FILE" ]]; then
  echo "Missing $ENV_FILE. Copy .env.example to .env and fill required keys." >&2
  exit 2
fi

set -a
# shellcheck disable=SC1090
source "$ENV_FILE"
set +a

export FREEQ_SERVER="${FREEQ_SERVER:-wss://irc.freeq.at/irc}"
export FREEQ_CHANNEL="${FREEQ_CHANNEL:-#alexandria}"
export RAVEN_FREEQ_NICK="${RAVEN_FREEQ_NICK:-Raven}"
export RAVEN_IDENTITY_NAME="${RAVEN_IDENTITY_NAME:-raven}"
export DEEPGRAM_MODEL="${DEEPGRAM_MODEL:-nova-3}"
export RAVEN_ANSWER_PROVIDER="${RAVEN_ANSWER_PROVIDER:-anthropic}"
export RAVEN_ANSWER_MODEL="${RAVEN_ANSWER_MODEL:-claude-opus-4-7}"
export INCEPTION_REASONING_EFFORT="${INCEPTION_REASONING_EFFORT:-instant}"
export RAVEN_RENDER_BACKEND="${RAVEN_RENDER_BACKEND:-svg}"
export RAVEN_AGENT_WORKDIR="${RAVEN_AGENT_WORKDIR:-$ROOT}"
export RAVEN_AGENT_COMMAND="${RAVEN_AGENT_COMMAND:-$ROOT/bin/raven-claude-agent}"
export RAVEN_ALEXANDRIA_PLUGIN_PATH="${RAVEN_ALEXANDRIA_PLUGIN_PATH:-$RAVEN_AGENT_WORKDIR/.claude/plugins/alexandria}"
export RAVEN_AGENT_PERMISSION_MODE="${RAVEN_AGENT_PERMISSION_MODE:-dontAsk}"
export RAVEN_AGENT_MAX_TURNS="${RAVEN_AGENT_MAX_TURNS:-8}"
export RAVEN_AGENT_TIMEOUT_SECS="${RAVEN_AGENT_TIMEOUT_SECS:-300}"
export RUST_LOG="${RAVEN_RUST_LOG:-freeq_raven=info,freeq_sdk=info,freeq_av=info,moq_native=warn}"

RAVEN_BIN="${RAVEN_BIN:-$ROOT/target/release/freeq-raven}"
if [[ ! -x "$RAVEN_BIN" ]]; then
  "$ROOT/bin/freeq-raven-bootstrap"
fi

args=(
  --server "$FREEQ_SERVER"
  --channel "$FREEQ_CHANNEL"
  --name "$RAVEN_IDENTITY_NAME"
  --nick "$RAVEN_FREEQ_NICK"
  --render-backend "$RAVEN_RENDER_BACKEND"
  --ghostly-character raven
  --deepgram-model "$DEEPGRAM_MODEL"
  --answer-provider "$RAVEN_ANSWER_PROVIDER"
  --answer-model "$RAVEN_ANSWER_MODEL"
  --inception-reasoning-effort "$INCEPTION_REASONING_EFFORT"
  --agent-command "$RAVEN_AGENT_COMMAND"
  --agent-workdir "$RAVEN_AGENT_WORKDIR"
  --alexandria-plugin-path "$RAVEN_ALEXANDRIA_PLUGIN_PATH"
  --agent-permission-mode "$RAVEN_AGENT_PERMISSION_MODE"
  --agent-max-turns "$RAVEN_AGENT_MAX_TURNS"
  --agent-timeout-secs "$RAVEN_AGENT_TIMEOUT_SECS"
  --elevenlabs-model "${ELEVENLABS_MODEL:-eleven_turbo_v2_5}"
)

if [[ "${RAVEN_AUTO_START_SESSION:-0}" == "1" ]]; then
  args+=(--start-session-in "$FREEQ_CHANNEL")
fi
if [[ "${RAVEN_NO_PROACTIVE:-0}" == "1" ]]; then
  args+=(--no-proactive)
fi
if [[ "${RAVEN_NO_AMBIENT:-0}" == "1" ]]; then
  args+=(--no-ambient)
fi
if [[ -n "${RAVEN_SFU_URL:-}" ]]; then
  args+=(--sfu-url "$RAVEN_SFU_URL")
fi
if [[ -n "${RAVEN_PEER_AGENTS:-}" ]]; then
  args+=(--peer-agents "$RAVEN_PEER_AGENTS")
fi

cd "$ROOT"
exec "$RAVEN_BIN" "${args[@]}"
