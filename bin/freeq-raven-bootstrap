#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CHECK_ONLY=0
if [[ "${1:-}" == "--check" ]]; then
  CHECK_ONLY=1
fi

if ! command -v cargo >/dev/null 2>&1; then
  echo "cargo is required. Install Rust with rustup, then re-run this command." >&2
  exit 2
fi

cd "$ROOT"

if [[ "$CHECK_ONLY" == "1" ]]; then
  cargo check -p freeq-raven
  cargo test -p freeq-raven --lib --test identity_test
  exit 0
fi

cargo build --release -p freeq-raven
echo "Built $ROOT/target/release/freeq-raven"
