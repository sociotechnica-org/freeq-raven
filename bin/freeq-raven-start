#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
RUNTIME_DIR="$ROOT/.runtime"
PID_FILE="$RUNTIME_DIR/freeq-raven.pid"
LOG_FILE="$RUNTIME_DIR/freeq-raven.log"
TMUX_SESSION="${RAVEN_TMUX_SESSION:-freeq-raven}"
mkdir -p "$RUNTIME_DIR"

if command -v tmux >/dev/null 2>&1 && tmux has-session -t "$TMUX_SESSION" 2>/dev/null; then
  echo "Raven already running in tmux session: $TMUX_SESSION"
  exit 0
fi

if [[ -f "$PID_FILE" ]]; then
  pid="$(cat "$PID_FILE")"
  if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
    echo "Raven already running: pid $pid"
    exit 0
  fi
fi

if command -v tmux >/dev/null 2>&1; then
  printf '\n===== freeq-raven start %s =====\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" >>"$LOG_FILE"
  tmux new-session -d -s "$TMUX_SESSION" "cd \"$ROOT\" && exec \"$ROOT/bin/freeq-raven\" >>\"$LOG_FILE\" 2>&1"
  tmux display-message -p -t "$TMUX_SESSION" '#{pane_pid}' >"$PID_FILE"
  echo "Started Raven in tmux session: $TMUX_SESSION"
else
  printf '\n===== freeq-raven start %s =====\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" >>"$LOG_FILE"
  nohup "$ROOT/bin/freeq-raven" >>"$LOG_FILE" 2>&1 &
  pid=$!
  echo "$pid" >"$PID_FILE"
  echo "Started Raven: pid $pid"
fi
echo "Log: $LOG_FILE"
