# Copy to .env and fill secrets locally. Do not commit .env.

FREEQ_SERVER=wss://irc.freeq.at/irc
FREEQ_CHANNEL=#alexandria
RAVEN_FREEQ_NICK=Raven
RAVEN_IDENTITY_NAME=raven

# Required for the live AV/chat loop.
INCEPTION_API_KEY=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# Optional model/provider controls.
DEEPGRAM_MODEL=nova-3
RAVEN_ANSWER_PROVIDER=inception
RAVEN_ANSWER_MODEL=mercury-2
INCEPTION_REASONING_EFFORT=instant
ELEVENLABS_MODEL=eleven_turbo_v2_5
RAVEN_RENDER_BACKEND=svg
RAVEN_SFU_URL=
RAVEN_PEER_AGENTS=

# Heavy work target. Set this to the product repo Raven should inspect/edit.
RAVEN_TOOL_WORKDIR=/absolute/path/to/target-product-repo

# Heavy work runner. Defaults to bin/raven-claude-runner from the wrapper.
# RAVEN_TOOL_COMMAND=/absolute/path/to/freeq-raven/bin/raven-claude-runner

# Local trusted-machine mode: leave RAVEN_CLAUDE_ENDPOINT unset and make sure
# the authenticated `claude` CLI is on PATH.
#
# Railway/Tailscale mode: set this to a Tailnet-only Claude Code worker.
# RAVEN_CLAUDE_ENDPOINT=http://claude-code-1:8765
# RAVEN_CLAUDE_ENDPOINT_TOKEN=

# Optional Claude Code controls for heavy work.
# RAVEN_CLAUDE_MODEL=sonnet
# RAVEN_CLAUDE_PERMISSION_MODE=bypassPermissions

# Legacy Codex fallback, explicit only:
# RAVEN_TOOL_COMMAND=/absolute/path/to/freeq-raven/bin/raven-tool-runner
# RAVEN_TOOL_MODEL=

# If set to 1, Raven starts a call when no call is active.
RAVEN_AUTO_START_SESSION=0
