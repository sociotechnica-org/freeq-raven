# Copy to .env and fill secrets locally. Do not commit .env.

FREEQ_SERVER=wss://irc.freeq.at/irc
FREEQ_CHANNEL=#alexandria
RAVEN_FREEQ_NICK=Raven
RAVEN_IDENTITY_NAME=raven

# Required for the live AV/chat loop.
ANTHROPIC_API_KEY=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# Optional model/provider controls.
DEEPGRAM_MODEL=nova-3
RAVEN_ANSWER_PROVIDER=anthropic
RAVEN_ANSWER_MODEL=claude-opus-4-7
INCEPTION_REASONING_EFFORT=instant
ELEVENLABS_MODEL=eleven_turbo_v2_5
RAVEN_ELEVENLABS_VOICE=aj0fZfXTBc7E3By4X8L2
RAVEN_RENDER_BACKEND=coin
RAVEN_SFU_URL=
RAVEN_PEER_AGENTS=

# Claude Agent SDK target. Set this to the product repo Raven should inspect/edit.
RAVEN_AGENT_WORKDIR=/absolute/path/to/target-product-repo
# Optional override; bin/freeq-raven defaults this to its own absolute helper path.
# RAVEN_AGENT_COMMAND=/absolute/path/to/freeq-raven/bin/raven-claude-agent
RAVEN_ALEXANDRIA_PLUGIN_PATH=/absolute/path/to/target-product-repo/.claude/plugins/alexandria
RAVEN_AGENT_PERMISSION_MODE=dontAsk
RAVEN_AGENT_MAX_TURNS=8
RAVEN_AGENT_TIMEOUT_SECS=300
# Set to 0 to disable concise Claude Agent SDK event logs.
RAVEN_AGENT_TRACE=1

# Optional: keep direct Inception fallback available when --agent-command is unset.
INCEPTION_API_KEY=

# If set to 1, Raven starts a call when no call is active.
RAVEN_AUTO_START_SESSION=0
